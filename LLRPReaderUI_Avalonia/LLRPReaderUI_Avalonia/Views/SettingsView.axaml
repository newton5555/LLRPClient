<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:gb="using:GroupBox.Avalonia.Controls"
             xmlns:vm="using:LLRPReaderUI_Avalonia.ViewModels"
             x:Class="LLRPReaderUI_Avalonia.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             x:Name="Root">
    <Grid Margin="16" RowDefinitions="*,16,Auto,32">
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <gb:GroupBox Header="Keepalive 配置" Margin="0,0,0,12">
                    <Grid Margin="10" ColumnDefinitions="200,220" RowDefinitions="Auto,8,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="启用 Keepalive" />
                        <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding EnableKeepalive}" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Keepalive 间隔(ms)" />
                        <TextBox Grid.Row="2" Grid.Column="1" Height="30" Text="{Binding KeepaliveIntervalMs}" />
                    </Grid>
                </gb:GroupBox>

                <gb:GroupBox Header="RF 与盘点配置" Margin="0,0,0,12">
                    <Grid Margin="10" ColumnDefinitions="200,220" RowDefinitions="Auto,8,Auto,8,Auto,8,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="RF Mode" />
                        <ComboBox Grid.Row="0" Grid.Column="1" Height="30" ItemsSource="{Binding RfModeOptions}" SelectedItem="{Binding SelectedRfModeOption}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayText}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Session (0-3)" />
                        <ComboBox Grid.Row="2" Grid.Column="1" Height="30" SelectedIndex="{Binding Session}">
                            <ComboBoxItem Content="0" />
                            <ComboBoxItem Content="1" />
                            <ComboBoxItem Content="2" />
                            <ComboBoxItem Content="3" />
                        </ComboBox>

                        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="TagPopulationEstimate" />
                        <TextBox Grid.Row="4" Grid.Column="1" Height="30" Text="{Binding TagPopulationEstimate}" />

                        <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap" Text="连接后暂缓上报（需 ENABLE_EVENTS_AND_REPORTS）"/>
                        <CheckBox Grid.Row="6" Grid.Column="1" IsChecked="{Binding HoldEventsAndReportsUponReconnect}" VerticalAlignment="Center" />
                    </Grid>
                </gb:GroupBox>

                <gb:GroupBox Header="AntennaConfigGroup（按天线）" Margin="0,0,0,12">
                    <StackPanel Margin="10">
                        <Grid Margin="0,0,0,8" ColumnDefinitions="140,90,200,200">
                            <TextBlock Grid.Column="0" Text="端口"  />
                            <TextBlock Grid.Column="1" Text="启用"  />
                            <TextBlock Grid.Column="2" Text="TxPower(dBm)" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="RxSensitivity(dBm)" FontWeight="SemiBold" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Antennas}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8" ColumnDefinitions="140,90,200,200">
                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding PortNumber, StringFormat=天线 {0}}" />
                                        <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding IsEnabled}" />
                                        <ComboBox Grid.Column="2" Height="28" ItemsSource="{Binding $parent[ItemsControl].DataContext.TxPowerOptions}" SelectedItem="{Binding TxPowerInDbm}" />
                                        <ComboBox Grid.Column="3" Height="28" ItemsSource="{Binding $parent[ItemsControl].DataContext.RxSensitivityOptions}" SelectedItem="{Binding RxSensitivityInDbm}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </gb:GroupBox>

                <gb:GroupBox Header="Reader 上报事件（只读）" Margin="0,0,0,12">
                    <ItemsControl Margin="10" ItemsSource="{Binding ReaderEventNotifications}" />
                </gb:GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
            <Button Height="32" Width="120" Content="获取参数" Command="{Binding QueryDeviceSettingsCommand}" />
            <Button Height="32" Width="120" Content="保存参数" Command="{Binding SaveSettingsCommand}" />
            <Button Height="32" Width="120" Content="获取设备状态" Command="{ReflectionBinding $parent[Window].DataContext.QueryStatusCommand}" />
            <Button Height="32" Width="120" Content="恢复出厂" Command="{Binding ResetFactoryDefaultsCommand}" />
        </StackPanel>

        <TextBlock Grid.Row="3" Margin="4,0,0,0" VerticalAlignment="Center" Text="{Binding SaveResult}" />
    </Grid>
</UserControl>
