<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LLRPReaderUI_Avalonia.ViewModels"
             x:Class="LLRPReaderUI_Avalonia.Views.LogView"
             x:DataType="vm:LogViewModel">
    <Grid Margin="16" RowDefinitions="Auto,8,*">
        <Border Grid.Row="0" Padding="12">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="14"  Text="{Binding TotalLogCount, StringFormat=日志总数: {0}}" />
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Margin="8">
                    <Button Content="清空全部" Padding="12,6" Command="{Binding ClearLogsCommand}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,10,0,0" Spacing="16">
                    <CheckBox IsChecked="{Binding ShowOperationLogs, Mode=TwoWay}" Content="操作日志" />
                    <CheckBox IsChecked="{Binding ShowLlrpMessageLogs, Mode=TwoWay}" Content="LLRP 消息日志" />
                    <CheckBox IsChecked="{Binding ShowRawFrameLogs, Mode=TwoWay}" Content="原始报文收发" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <Border IsVisible="{Binding ShowOperationLogs}" Padding="12">
                    <Grid RowDefinitions="Auto,8,*" ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"  Text="操作日志" />
                        <Button Grid.Row="0" Grid.Column="1" Content="清空" Padding="10,4" Command="{Binding ClearOperationLogsCommand}" />
                        <ListBox x:Name="OperationListBox" Grid.Row="2" Grid.ColumnSpan="2" ItemsSource="{Binding OperationEntries}" SelectionMode="Multiple" FontFamily="Consolas" FontSize="11" />
                    </Grid>
                </Border>

                <Border IsVisible="{Binding ShowLlrpMessageLogs}" Padding="12">
                    <Grid RowDefinitions="Auto,8,*" ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"  Text="LLRP 消息日志" />
                        <Button Grid.Row="0" Grid.Column="1" Content="清空" Padding="10,4" Command="{Binding ClearLlrpMessageLogsCommand}" />
                        <ListBox x:Name="LlrpMessageListBox" Grid.Row="2" Grid.ColumnSpan="2" ItemsSource="{Binding LlrpMessageEntries}" SelectionMode="Multiple" FontFamily="Consolas" FontSize="11" />
                    </Grid>
                </Border>

                <Border IsVisible="{Binding ShowRawFrameLogs}" Padding="12">
                    <Grid RowDefinitions="Auto,8,*" ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"  Text="原始报文收发" />
                        <Button Grid.Row="0" Grid.Column="1" Content="清空" Padding="10,4" Command="{Binding ClearRawFrameLogsCommand}" />
                        <ListBox x:Name="RawPacketListBox" Grid.Row="2" Grid.ColumnSpan="2" ItemsSource="{Binding RawPacketEntries}" SelectionMode="Multiple" FontFamily="Consolas" FontSize="11" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
