<UserControl x:Class="LLRPReaderUI_WPF.Views.ReadWriteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:viewmodels="clr-namespace:LLRPReaderUI_WPF.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:ReadWriteViewModel}"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16" MaxWidth="800">
            <GroupBox Header="读取配置">
                <Grid Margin="10">
                    <Grid.Resources>
                        <SolidColorBrush x:Key="ReadRequiredForeground" Color="#0B5CAD" />
                        <SolidColorBrush x:Key="WriteRequiredForeground" Color="#B54708" />
                        <SolidColorBrush x:Key="ReadRequiredBackground" Color="#EAF3FF" />
                        <SolidColorBrush x:Key="WriteRequiredBackground" Color="#FFF3E8" />
                        <DrawingBrush x:Key="BothRequiredBackground"
                                      Viewbox="0,0,6,6"
                                      ViewboxUnits="Absolute"
                                      Viewport="0,0,6,6"
                                      ViewportUnits="Absolute"
                                      TileMode="Tile"
                                      Stretch="None">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="#F7FAFC" Geometry="M0,0 H6 V6 H0 Z" />
                                    <GeometryDrawing Brush="#DCEBFF" Geometry="M0,0 H3 V3 H0 Z" />
                                    <GeometryDrawing Brush="#FFE5D3" Geometry="M3,3 H6 V6 H3 Z" />
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Grid.Resources>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                               Foreground="#4A5568"
                               Text="图例：蓝=读必填，橙=写必填；同时必填=蓝橙混合" />

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="目标标签类型" />
                    <ComboBox Grid.Row="2" Grid.Column="1"
                              Height="32"
                              ItemsSource="{Binding TargetTagBanks}"
                              SelectedItem="{Binding SelectedTargetTagBank}"
                              ToolTip="选择用于定位标签的内存区（EPC/TID）" />

                    <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center" FontWeight="SemiBold">
                            <TextBlock.Text>
                                <Binding Path="SelectedTargetTagBank" StringFormat="目标{0} *" />
                            </TextBlock.Text>
                        </TextBlock>
                       
                    </StackPanel>
                    <Border Grid.Row="4"
                            Grid.Column="1"
                            Height="32"
                            BorderBrush="{StaticResource WriteRequiredForeground}"
                            BorderThickness="1">
                        <TextBox Margin="1"
                                 VerticalContentAlignment="Center"
                                 Padding="4,0,4,0"
                                 Background="{StaticResource BothRequiredBackground}"
                                 BorderBrush="{StaticResource ReadRequiredForeground}"
                                 Text="{Binding TargetTagData, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="读写都必填：输入目标标签值（十六进制）" />
                    </Border>

                    <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="内存区" />
                    <ComboBox Grid.Row="6" Grid.Column="1" 
                              Height="32"
                              ItemsSource="{Binding MemoryBanks}"
                              SelectedItem="{Binding SelectedMemoryBank}"
                              ToolTip="选择要读取的内存区" />

                    <StackPanel Grid.Row="8" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="Word 起始地址 *" />
                       
                    </StackPanel>
                    <Border Grid.Row="8"
                            Grid.Column="1"
                            Height="32"
                            BorderBrush="{StaticResource WriteRequiredForeground}"
                            BorderThickness="1">
                        <TextBox Margin="1"
                                 VerticalContentAlignment="Center"
                                 Padding="4,0,4,0"
                                 Background="{StaticResource BothRequiredBackground}"
                                 BorderBrush="{StaticResource ReadRequiredForeground}"
                                 Text="{Binding WordPointer, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="读写都必填：起始 Word 地址，从 0 开始" />
                    </Border>

                    <TextBlock Grid.Row="10" Grid.Column="0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource ReadRequiredForeground}"
                               FontWeight="SemiBold"
                               Text="Word 数量 *" />
                    <TextBox Grid.Row="10" Grid.Column="1" 
                             VerticalContentAlignment="Center"
                             Height="32" 
                             Background="{StaticResource ReadRequiredBackground}"
                             BorderBrush="{StaticResource ReadRequiredForeground}"
                             Text="{Binding WordCount, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="读取必填：要读取的 Word 数量" />

                    <TextBlock Grid.Row="12" Grid.Column="0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource WriteRequiredForeground}"
                               FontWeight="SemiBold"
                               Text="写入数据 *" />
                    <TextBox Grid.Row="12" Grid.Column="1" 
                             VerticalContentAlignment="Center"
                             Height="32" 
                             Background="{StaticResource WriteRequiredBackground}"
                             BorderBrush="{StaticResource WriteRequiredForeground}"
                             Text="{Binding WriteData, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="写入必填：输入要写入的数据（十六进制，长度需为4的倍数）" />

                    <TextBlock Grid.Row="14" Grid.Column="0" VerticalAlignment="Center" Text="访问密码" />
                    <TextBox Grid.Row="14" Grid.Column="1" 
                             VerticalContentAlignment="Center"
                             Height="32" 
                             Text="{Binding AccessPassword, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="访问密码（十六进制，8位），默认 00000000" />
                </Grid>
            </GroupBox>

            <GroupBox Header="操作" Margin="0,10,0,0">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal">
                        <Button Height="36"
                                Width="120"
                                Content="读取内存"
                                Command="{Binding ReadMemoryCommand}"
                                Style="{DynamicResource MahApps.Styles.Button.Accent}" />
                        <Button Height="36"
                                Width="120"
                                Margin="10,0,0,0"
                                Content="写入内存"
                            Command="{Binding WriteMemoryCommand}" />
                        <CheckBox Margin="10,0,0,0"
                                  VerticalAlignment="Center"
                                  Content="块写入"
                                  IsChecked="{Binding IsBlockWriteChecked}"
                                  IsEnabled="{Binding IsBlockWriteSupported}"
                                  ToolTip="仅当设备能力集支持时可用" />
                        <Button Height="36"
                                Width="120"
                                Margin="10,0,0,0"
                                Content="清空数据"
                                Command="{Binding ClearDataCommand}" />
                    </StackPanel>
                    <TextBlock Margin="0,10,0,0" 
                               Text="{Binding OperationResult}" 
                               Foreground="{DynamicResource MahApps.Brushes.Accent}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="读取结果" Margin="0,10,0,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="十六进制数据：" />
                    <TextBox Grid.Row="2" 
                             Height="100"
                             Text="{Binding ReadData, Mode=OneWay}" 
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             IsReadOnly="True"
                             FontFamily="Consolas" />
                </Grid>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
