<UserControl
    x:Class="LLRPReaderUI_WPF.Views.InventoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:viewmodels="clr-namespace:LLRPReaderUI_WPF.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:InventoryViewModel}"
    d:Height="600"
    mc:Ignorable="d">
    <UserControl.Resources>
        <x:Array x:Key="DesignReceivedTags" Type="{x:Type viewmodels:InventoryTagItemViewModel}">
            <viewmodels:InventoryTagItemViewModel
                Antenna="1"
                AttachedData="E28011712000013FADFC09A0"
                ChannelMhz="920.625"
                Epc="E20034120123456789012345"
                ReceiveTime="2026-03-02T10:12:30.123"
                Rssi="-45.2"
                SeenCount="3" />
            <viewmodels:InventoryTagItemViewModel
                Antenna="2"
                AttachedData="E280117120001410AE2209A0"
                ChannelMhz="921.125"
                Epc="E2801170000002084F2A1BCD"
                ReceiveTime="2026-03-02T10:12:31.008"
                Rssi="-51.7"
                SeenCount="1" />
            <viewmodels:InventoryTagItemViewModel
                Antenna="4"
                AttachedData="E280110C20007A91BCC50A11"
                ChannelMhz="922.375"
                Epc="300833B2DDD9014000000001"
                ReceiveTime="2026-03-02T10:12:31.556"
                Rssi="-60.0"
                SeenCount="8" />
        </x:Array>
    </UserControl.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button
                Width="120"
                Height="32"
                Command="{Binding StartInventoryCommand}"
                Content="开始寻卡"
                Style="{DynamicResource MahApps.Styles.Button.Accent}" />
            <Button
                Width="120"
                Height="32"
                Margin="10,0,0,0"
                Command="{Binding StopInventoryCommand}"
                Content="停止寻卡" />
            <Button
                Width="120"
                Height="32"
                Margin="10,0,0,0"
                Command="{Binding ManualPullBufferedReportsCommand}"
                Content="手动拉缓存" />
            <Button
                Width="100"
                Height="32"
                Margin="10,0,0,0"
                Command="{Binding ClearReceivedDataCommand}"
                Content="清空数据" />
            <TextBlock
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                Text="{Binding InventoryState}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <TextBlock Margin="0,0,16,0" Text="{Binding TotalReports, StringFormat=报告包: {0}}" />
            <TextBlock Margin="0,0,16,0" Text="{Binding TotalTags, StringFormat=标签总数: {0}}" />
            <TextBlock Text="{Binding UniqueTagCount, StringFormat=唯一 EPC: {0}}" />
        </StackPanel>

        <Border
            Grid.Row="4"
            Padding="8"
            Background="{DynamicResource MahApps.Brushes.ThemeBackground}">
            <DataGrid
                x:Name="InventoryDataGrid"
                d:ItemsSource="{StaticResource ResourceKey=DesignReceivedTags}"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                IsReadOnly="True"
                ItemsSource="{Binding ReceivedTags}"
                PreviewKeyDown="InventoryDataGrid_OnPreviewKeyDown"
                SelectionMode="Extended"
                SelectionUnit="FullRow">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Click="CopyEpcMenuItem_OnClick" Header="复制 EPC" />
                        <MenuItem Click="CopyAttachedDataMenuItem_OnClick" Header="复制附加数据" />
                        <Separator />
                        <MenuItem Click="CopySelectedRowsMenuItem_OnClick" Header="复制选中行" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="auto"
                        Binding="{Binding ReceiveTime, StringFormat=yy/MM/dd HH:mm:ss.fff}"
                        Header="接收时间" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Epc}"
                        Header="EPC" />
                    <DataGridTextColumn
                        Width="auto"
                        Binding="{Binding Antenna}"
                        Header="天线" />
                    <DataGridTextColumn
                        Width="auto"
                        Binding="{Binding ChannelMhz}"
                        Header="信道(MHz)" />
                    <DataGridTextColumn
                        Width="auto"
                        Binding="{Binding Rssi}"
                        Header="RSSI(dBm)" />
                    <DataGridTextColumn
                        Width="auto"
                        Binding="{Binding SeenCount}"
                        Header="SeenCount" />
                    <DataGridTextColumn
                        Width="220"
                        Binding="{Binding AttachedData}"
                        Header="附加数据" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
