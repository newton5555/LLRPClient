<UserControl x:Class="LLRPReaderUI_WPF.Views.GpioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:LLRPReaderUI_WPF.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:GpioViewModel}"
             mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="GPI 配置（可保存）" Margin="0,0,0,12">
                    <StackPanel Margin="10">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="端口" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="启用" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="当前电平" FontWeight="SemiBold" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Gpis}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding PortNumber, StringFormat=GPI {0}}" />
                                        <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding IsEnabled}" />
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding CurrentStateText}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="GPO 输出（即时下发）" Margin="0,0,0,12">
                    <StackPanel Margin="10">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="端口" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="输出高电平" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="当前电平" FontWeight="SemiBold" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Gpos}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="140" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding PortNumber, StringFormat=GPO {0}}" />
                                        <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding DesiredState}" />
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding CurrentStateText}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Height="32"
                    Width="120"
                    Margin="0,0,8,0"
                    Content="获取GPIO"
                    Command="{Binding QueryGpioSettingsCommand}" />
            <Button Height="32"
                    Width="120"
                    Margin="0,0,8,0"
                    Content="保存GPI"
                    Command="{Binding SaveGpiSettingsCommand}" />
            <Button Height="32"
                    Width="120"
                    Content="下发GPO"
                    Command="{Binding ApplyGpoStatesCommand}" />
        </StackPanel>

        <TextBlock Grid.Row="3" Margin="4,0,0,0" VerticalAlignment="Center" Text="{Binding OperationResult}" />
    </Grid>
</UserControl>
