<UserControl x:Class="LLRPReaderUI_WPF.Views.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:viewmodels="clr-namespace:LLRPReaderUI_WPF.ViewModels" xmlns:converters="clr-namespace:LLRPReaderUI_WPF.Converters" d:DataContext="{d:DesignInstance Type=viewmodels:LogViewModel}"
             mc:Ignorable="d" d:Width="600" d:Height="500">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BooleanToStarGridLengthConverter x:Key="BoolToStarGridLengthConverter" />
    </UserControl.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header: 统计和全局操作 -->
        <Border Grid.Row="0" Padding="12" Background="{DynamicResource MahApps.Brushes.ThemeBackground}" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           VerticalAlignment="Center"
                           FontSize="14" 
                           FontWeight="SemiBold">
                    <Run Text="日志总数: " />
                    <Run Text="{Binding TotalLogCount,Mode=OneWay}" Foreground="DodgerBlue" FontWeight="Bold" />
                </TextBlock>

                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Margin="8">
                    <Button Content="清空全部" Padding="12,6" Command="{Binding ClearLogsCommand}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,10,0,0">
                    <CheckBox Margin="0,0,16,0" IsChecked="{Binding ShowOperationLogs}">
                        <TextBlock>
                            <Run Text="📋 操作日志" />
                            <Run Text="{Binding OperationEntries.Count,Mode=OneWay, StringFormat=(0)}" Foreground="DodgerBlue" FontSize="12" />
                        </TextBlock>
                    </CheckBox>
                    <CheckBox Margin="0,0,16,0" IsChecked="{Binding ShowLlrpMessageLogs}">
                        <TextBlock>
                            <Run Text="📡 LLRP 消息日志" />
                            <Run Text="{Binding LlrpMessageEntries.Count,Mode=OneWay, StringFormat=(0)}" Foreground="DodgerBlue" FontSize="12" />
                        </TextBlock>
                    </CheckBox>
                    <CheckBox IsChecked="{Binding ShowRawFrameLogs}">
                        <TextBlock>
                            <Run Text="🔧 原始报文收发" />
                            <Run Text="{Binding RawPacketEntries.Count,Mode=OneWay, StringFormat=(0)}" Foreground="DodgerBlue" FontSize="12" />
                        </TextBlock>
                    </CheckBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 日志内容区 -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="{Binding ShowOperationLogs, Converter={StaticResource BoolToStarGridLengthConverter}}" />
                <RowDefinition Height="{Binding ShowLlrpMessageLogs, Converter={StaticResource BoolToStarGridLengthConverter}}" />
                <RowDefinition Height="{Binding ShowRawFrameLogs, Converter={StaticResource BoolToStarGridLengthConverter}}" />
            </Grid.RowDefinitions>

            <!-- 操作日志 -->
            <Border Grid.Row="0" Padding="12" Margin="0,0,0,12"
                    Visibility="{Binding ShowOperationLogs, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="{DynamicResource MahApps.Brushes.ThemeBackground}" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold">
                        <TextBlock>
                            <Run Text="📋 操作日志" />
                            <Run Text="{Binding OperationEntries.Count,Mode=OneWay, StringFormat=(0)}" Foreground="DodgerBlue" FontSize="12" />
                        </TextBlock>
                    </TextBlock>

                    <Button Grid.Row="0" Grid.Column="2"
                            Content="清空"
                            Padding="10,4"
                            Command="{Binding ClearOperationLogsCommand}" />

                    <ListBox x:Name="OperationListBox"
                             Grid.Row="2" Grid.ColumnSpan="3"
                             ItemsSource="{Binding OperationEntries,Mode=OneWay}"
                             ScrollViewer.CanContentScroll="True"
                             VirtualizingPanel.ScrollUnit="Pixel"
                             SelectionMode="Extended"
                             Background="{DynamicResource MahApps.Brushes.Control.Background}"
                             Foreground="{DynamicResource MahApps.Brushes.Text}"
                             FontFamily="Consolas"
                             FontSize="11" />
                </Grid>
            </Border>

            <!-- LLRP 消息日志 -->
            <Border Grid.Row="1" Padding="12" Margin="0,0,0,12"
                    Visibility="{Binding ShowLlrpMessageLogs, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="{DynamicResource MahApps.Brushes.ThemeBackground}" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold">
                        <TextBlock>
                            <Run Text="📡 LLRP 消息日志" />
                            <Run Text="{Binding LlrpMessageEntries.Count,Mode=OneWay, StringFormat=(0)}" Foreground="DodgerBlue" FontSize="12" />
                        </TextBlock>
                    </TextBlock>

                    <Button Grid.Row="0" Grid.Column="2"
                            Content="清空"
                            Padding="10,4"
                            Command="{Binding ClearLlrpMessageLogsCommand}" />

                    <ListBox x:Name="LlrpMessageListBox"
                             Grid.Row="2" Grid.ColumnSpan="3"
                             ItemsSource="{Binding LlrpMessageEntries,Mode=OneWay}"
                             ScrollViewer.CanContentScroll="True"
                             VirtualizingPanel.ScrollUnit="Pixel"
                             SelectionMode="Extended"
                             Background="{DynamicResource MahApps.Brushes.Control.Background}"
                             Foreground="{DynamicResource MahApps.Brushes.Text}"
                             FontFamily="Consolas"
                             FontSize="11" />
                </Grid>
            </Border>

            <!-- 原始报文 -->
            <Border Grid.Row="2" Padding="12"
                    Visibility="{Binding ShowRawFrameLogs, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="{DynamicResource MahApps.Brushes.ThemeBackground}" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold">
                        <TextBlock>
                            <Run Text="🔧 原始报文收发" />
                            <Run Text="{Binding RawPacketEntries.Count,Mode=OneWay, StringFormat=(0)}" Foreground="DodgerBlue" FontSize="12" />
                        </TextBlock>
                    </TextBlock>

                    <Button Grid.Row="0" Grid.Column="2"
                            Content="清空"
                            Padding="10,4"
                            Command="{Binding ClearRawFrameLogsCommand}" />

                    <ListBox x:Name="RawPacketListBox"
                             Grid.Row="2" Grid.ColumnSpan="3"
                             ItemsSource="{Binding RawPacketEntries,Mode=OneWay}"
                             ScrollViewer.CanContentScroll="True"
                             VirtualizingPanel.ScrollUnit="Pixel"
                             SelectionMode="Extended"
                             Background="{DynamicResource MahApps.Brushes.Control.Background}"
                             Foreground="{DynamicResource MahApps.Brushes.Text}"
                             FontFamily="Consolas"
                             FontSize="11" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
